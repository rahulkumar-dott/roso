# Copy to .env and fill in only what you have. Anything left unset runs in
# stub/mock mode - no code changes needed later when you add a real key.

# Default local file DB:
DATABASE_URL=sqlite:///./poc.db

# Optional local PostgreSQL:
# DATABASE_URL=postgresql+psycopg://roso:roso_dev_password@127.0.0.1:5432/roso_poc

# Optional local PostgreSQL with pgvector:
# DATABASE_URL=postgresql+psycopg://roso:roso_dev_password@127.0.0.1:5433/roso_poc

# Phase 2+ (optional - unset = stub mode)
OPENAI_API_KEY=
GOOGLE_PLACES_API_KEY=

# Phase 7 live Viator ingestion (optional - unset = fixture mode only)
VIATOR_API_BASE_URL=https://api.sandbox.viator.com/partner
VIATOR_API_KEY=
VIATOR_PARTNER_ID=

# Phase 7 keyword intelligence via SEMrush (optional)
SEMRUSH_API_KEY=
SEMRUSH_API_BASE_URL=https://api.semrush.com/
SEMRUSH_DATABASE=us

# Phase 7 vector similarity via sentence-transformers + pgvector
VECTOR_SIMILARITY_ENABLED=true
SENTENCE_TRANSFORMER_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Phase 3 live drafting via Groq (optional - unset = template stub mode)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
